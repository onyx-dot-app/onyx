# Web dev image for the local-cluster workflow (docs/dev/local-cluster.md).
#
# Built and pushed to the local k3d registry by the Tiltfile. The chart's
# webserver.image is pointed at this image; webserver.command overrides the
# entrypoint to `bun dev` so Next.js runs in dev mode with HMR.
#
# Tilt live_updates source files via sync() into /app on every save; bun's
# Next.js dev server detects the change and HMR-reloads in the browser.
#
# Not used in production; this Dockerfile lives alongside the prod
# Dockerfile in web/ and is only referenced by the dev path.

FROM node:24-alpine@sha256:d1b3b4da11eefd5941e7f0b9cf17783fc99d9c6fc34884a665f40a06dbdfc94f

# bun (matches the version used by the production Dockerfile).
COPY --from=oven/bun:1-alpine@sha256:5acc90a93e91ff07bf72aa90a7c9f0fa189765aec90b47bdbf2152d2196383c0 /usr/local/bin/bun /usr/local/bin/bun
COPY --from=oven/bun:1-alpine@sha256:5acc90a93e91ff07bf72aa90a7c9f0fa189765aec90b47bdbf2152d2196383c0 /usr/local/bin/bunx /usr/local/bin/bunx

# libc6-compat: same rationale as the prod image (Next.js compiled binaries
# expect glibc symbols).
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Install deps. opal's workspace `prepare` hook (which runs `tsup`) races
# bun's workspace dependency linking on a cold install — tsup tries to
# resolve tailwind-merge from lib/opal/ but its local node_modules isn't
# populated yet because root and opal pin incompatible versions of
# tailwind-merge (^3 vs ^2) that can't be hoisted to a single dir.
# `bun install --ignore-scripts` doesn't skip workspace-package prepare
# hooks in bun 1.x.
#
# Fix: strip the prepare hook before install, then build opal explicitly
# once all deps are linked. The package.json edit lives only inside this
# image layer; the source tree on disk is untouched.
COPY package.json bun.lock tsconfig.json ./
COPY lib/opal/ ./lib/opal/

# Install with the committed lockfile so transitive deps land at the
# correct, host-matched versions. Two-pass workaround for an opal
# workspace bug: opal's `prepare` lifecycle hook runs `tsup` during
# `bun install`, but on a cold workspace install the workspace's local
# node_modules isn't populated when prepare fires — so tsup can't
# resolve `tailwind-merge` and the install fails. The first pass leaves
# deps linked but exits non-zero; the second pass re-runs prepare
# against the now-populated tree and succeeds.
#
# Prod's web/Dockerfile uses the same single `bun install --frozen-lockfile`
# and only avoids this in CI because the GHA `cache-from` restores the
# install layer from a prior image. Any commit that perturbs the install
# layer in prod will hit this same race — fix is queued in a separate
# focused PR.
#
# We do NOT rebuild opal in this image — a separate esbuild `@opal/*`
# path-alias issue surfaces when tsup runs from a fresh container.
# The host's already-built `lib/opal/dist/` is brought in by the
# `COPY . .` below.
RUN bun install --frozen-lockfile || true
RUN bun install --frozen-lockfile

# Copy the rest of the source tree. Tilt's live_update sync() overwrites
# anything we copy here on file changes, so the build-time contents are
# the cold-start state only.
COPY . .

ENV NEXT_TELEMETRY_DISABLED=1

EXPOSE 3000

# The chart's webserver.command in values-dev-app.yaml overrides this; the
# CMD below is a safe fallback if a developer runs the image standalone.
CMD ["bun", "run", "dev"]
