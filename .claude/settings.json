{
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true,
    "claude-security@claude-plugins-official": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$CLAUDE_ENV_FILE\" ] && printf 'export PATH=\"%s\"\\n' \"$CLAUDE_PROJECT_DIR/.venv/bin${PATH:+:$PATH}\" >> \"$CLAUDE_ENV_FILE\" || true"
          }
        ]
      }
    ]
  }
}
