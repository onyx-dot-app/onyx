#!/usr/bin/env bash
# Auto-loaded by direnv when you `cd` into the repo. Scopes kubectl / helm
# to the local k3d cluster created by `deployment/helm/dev/dev.sh up`, so
# stray commands from the repo root can't accidentally hit prod or staging.
#
# Setup (once per machine):
#   brew install direnv     # already in repo-root Brewfile
#   # add direnv hook to your shell — see https://direnv.net/docs/hook.html
#   # (zsh:  eval "$(direnv hook zsh)" in ~/.zshrc)
#   # (bash: eval "$(direnv hook bash)" in ~/.bashrc)
#   direnv allow .          # one-time approval per checkout
#
# After that, every shell entering this directory has KUBECONFIG pointed
# at ~/.kube/onyx-local.yaml automatically.
#
# See docs/dev/local-cluster.md.

if [ -f "$HOME/.kube/onyx-local.yaml" ]; then
  export KUBECONFIG="$HOME/.kube/onyx-local.yaml"
else
  # Don't fail — kubectl just isn't usable until dev.sh creates the file.
  # Echoing through stderr so direnv shows it once on cd.
  echo "warn: ~/.kube/onyx-local.yaml not found — run 'deployment/helm/dev/dev.sh up' to create the local k3d cluster" >&2
fi
