FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        openssl \
        jq \
        python3 \
        python3-pip \
        python3-venv \
        nodejs \
        npm \
        iputils-ping \
        netcat-openbsd \
        dnsutils \
    && rm -rf /var/lib/apt/lists/*

# pip is externally-managed on bookworm; allow user-wide installs into /usr/local.
RUN pip3 install --break-system-packages --no-cache-dir \
        requests \
        httpx \
        certifi

COPY install_ca.sh /usr/local/bin/install_ca.sh
COPY entrypoint-explicit.sh /usr/local/bin/entrypoint-explicit.sh
COPY entrypoint-transparent.sh /usr/local/bin/entrypoint-transparent.sh

RUN chmod +x /usr/local/bin/install_ca.sh \
             /usr/local/bin/entrypoint-explicit.sh \
             /usr/local/bin/entrypoint-transparent.sh

# CA bundle is mounted at build time via build context; we copy it into the
# image so each container has the trust anchor without runtime volume mounts.
# (The CA is generated by ca/gen-ca.sh before `docker compose build`.)
COPY ca.crt /usr/local/share/ca-certificates/onyx-ca.crt

RUN /usr/local/bin/install_ca.sh

# Used by entrypoints to coordinate readiness in transparent mode.
RUN mkdir -p /state && chmod 0777 /state

# Default work dir.
WORKDIR /work
