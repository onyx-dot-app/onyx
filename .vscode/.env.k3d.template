# =============================================================================
# .env.k3d — per-developer env for the local-cluster (Tilt + k3d) workflow.
# =============================================================================
#
# Copy to .vscode/.env.k3d and fill in the <REPLACE THIS> values:
#
#   cp .vscode/.env.k3d.template .vscode/.env.k3d
#
# .env.k3d is gitignored. dev.sh slurps every KEY=VALUE entry into the
# worktree's per-pod configMap on each `dev.sh up`.
#
# IMPORTANT: this file should ONLY contain keys the cluster should accept
# from a developer's local config. Chart-managed keys (connection hosts,
# infra credentials, per-worktree slugs) live in values-dev-infra.yaml /
# values-dev-app.yaml / the generated worktree values — adding them here
# does nothing useful and risks confusion.
#
# Specifically, do NOT add:
#   POSTGRES_HOST / POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB
#   REDIS_HOST / REDIS_PASSWORD / REDIS_DB_NUMBER*
#   OPENSEARCH_HOST / OPENSEARCH_ADMIN_PASSWORD / OPENSEARCH_*
#   S3_ENDPOINT_URL / S3_FILE_STORE_BUCKET_NAME / S3_AWS_*
#   MODEL_SERVER_HOST / INDEXING_MODEL_SERVER_HOST
#   SANDBOX_NAMESPACE / SANDBOX_API_SERVER_URL
#   INTERNAL_URL / DISABLE_VECTOR_DB / ENABLE_OPENSEARCH_*
#   ENABLE_CRAFT / ENABLE_DEBUGPY / DEBUGPY_PORT / HOSTNAME
#
# When the chart adds a new dev-tunable knob, append it here and devs pull
# the change explicitly.


# =============================================================================
# 1. Dev flags + logging
# =============================================================================
LOG_LEVEL=DEBUG
DEV_MODE=True
DEV_LOGGING_ENABLED=True
LOG_DANSWER_MODEL_INTERACTIONS=True
DISABLE_LLM_DOC_RELEVANCE=False
SKIP_WARM_UP=False
PYTHONPATH=.
PYTHONUNBUFFERED=1


# =============================================================================
# 2. LLM API keys  (set at least one)
# =============================================================================
OPENAI_API_KEY=<REPLACE THIS>
GEMINI_API_KEY=<REPLACE THIS>
# ANTHROPIC_API_KEY=<REPLACE THIS>
GEN_AI_MODEL_VERSION=gpt-5
FAST_GEN_AI_MODEL_VERSION=gpt-5-mini


# =============================================================================
# 3. Auth & password policy  (dev-friendly defaults; tighten for staging)
# =============================================================================
AUTH_TYPE=basic
REQUIRE_EMAIL_VERIFICATION=False
PASSWORD_MIN_LENGTH=1
PASSWORD_REQUIRE_UPPERCASE=False
PASSWORD_REQUIRE_LOWERCASE=False
PASSWORD_REQUIRE_DIGIT=False
PASSWORD_REQUIRE_SPECIAL_CHAR=False
NEXT_PUBLIC_FORGOT_PASSWORD_ENABLED=True

# Used to encrypt secrets at rest. Any 32-byte string works for dev.
ENCRYPTION_KEY_SECRET=<REPLACE THIS — any 32+ char string for dev>


# =============================================================================
# 4. Craft / Sandbox
# =============================================================================
SANDBOX_BACKEND=kubernetes
SANDBOX_CONTAINER_IMAGE=onyxdotapp/sandbox:dev
# Onyx Sandbox push private key. 32-byte ed25519 in base64. For dev a
# fixed value is fine — sandbox push only talks to the in-cluster api.
ONYX_SANDBOX_PUSH_PRIVATE_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=


# =============================================================================
# 5. Web frontend
# =============================================================================
DOMAIN=localhost
WEB_DOMAIN=http://localhost:13000
NEXT_PUBLIC_TEST_ENV=local-cluster


# =============================================================================
# 6. Enterprise / multi-tenant  (off by default)
# =============================================================================
ENABLE_PAID_ENTERPRISE_EDITION_FEATURES=True
LICENSE_ENFORCEMENT_ENABLED=False
MULTI_TENANT=False


# =============================================================================
# 7. Worker tuning  (override chart defaults if useful in dev)
# =============================================================================
# CELERY_WORKER_DOCFETCHING_CONCURRENCY=2
# CELERY_WORKER_DOCPROCESSING_CONCURRENCY=6


# =============================================================================
# 8. Vespa  (legacy — disable for dev; OpenSearch handles indexing)
# =============================================================================
ONYX_DISABLE_VESPA=True


# =============================================================================
# 9. Optional integrations  (uncomment as needed)
# =============================================================================
# OAUTH_CLIENT_ID=<REPLACE THIS>
# OAUTH_CLIENT_SECRET=<REPLACE THIS>

# Linear OAuth (for Linear connector)
# LINEAR_CLIENT_ID=<REPLACE THIS>
# LINEAR_CLIENT_SECRET=<REPLACE THIS>

# Exa search API
# EXA_API_KEY=<REPLACE THIS>

# Braintrust LLM observability
# BRAINTRUST_API_KEY=<REPLACE THIS>
# BRAINTRUST_PROJECT=<REPLACE THIS>

# PostHog product analytics
# POSTHOG_API_KEY=<REPLACE THIS>
# POSTHOG_HOST=https://us.i.posthog.com

# Email invites
# ENABLE_EMAIL_INVITES=True

# Show extra connectors in the UI
# SHOW_EXTRA_CONNECTORS=False
